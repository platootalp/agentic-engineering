# ============================================
# Production Environment Variables
# 生产环境变量 - 必须修改所有值
# ============================================

# 数据库（强密码必填）
POSTGRES_USER=regen_prod
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
POSTGRES_DB=regen_production
DATABASE_URL=postgresql+asyncpg://regen_prod:CHANGE_THIS@postgres:5432/regen_production

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO（强密码必填）
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_THIS_MINIO_KEY
MINIO_SECRET_KEY=CHANGE_THIS_MINIO_SECRET
MINIO_BUCKET_NAME=resumes

# 应用安全（强密钥必填）
SECRET_KEY=CHANGE_THIS_TO_32_CHAR_RANDOM_STRING

# 域名配置
DOMAIN=your-domain.com
VITE_API_URL=https://your-domain.com

# SSL 证书路径
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# 监控（可选）
SENTRY_DSN=
