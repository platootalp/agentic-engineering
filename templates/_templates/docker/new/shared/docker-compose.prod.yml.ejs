---
to: "<%= projectName %>/docker/docker-compose.prod.yml"
force: true
skip_if: "<%= backend === 'nextjs' || backend === 'nuxt3' %>"
---
version: "3.8"

services:
  frontend:
    build:
      context: ..
      dockerfile: docker/Dockerfile.frontend
    ports:
      - "3000:80"
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:80"]
      interval: 30s
      timeout: 5s
      retries: 3

  backend:
    build:
      context: ..
      dockerfile: docker/Dockerfile.backend
    ports:
      - "8000:8000"
    environment:
      - APP_ENV=production
<% if (backend === 'fastapi') { %>      - DATABASE_URL=${DATABASE_URL:-sqlite+aiosqlite:///./<%= projectName %>.db}
<% } else { %>      - DATABASE_URL=${DATABASE_URL:-file:./<%= projectName %>.db}
<% } %>    restart: unless-stopped
<% if (backend === 'fastapi') { %>    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8000/api/v1/health')"]
      interval: 30s
      timeout: 5s
      retries: 3
<% } else { %>    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:8000/api/v1/health"]
      interval: 30s
      timeout: 5s
      retries: 3
<% } %>
