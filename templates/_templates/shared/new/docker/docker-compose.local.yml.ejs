---
to: "<%= projectName %>/docker/docker-compose.local.yml"
skip_if: "<%= backend === 'nextjs' || backend === 'nuxt3' %>"
---
version: "3.8"

services:
  frontend:
    build:
      context: ../frontend
      dockerfile: ../docker/Dockerfile.frontend
    ports:
      - "3000:3000"
    volumes:
      - ../frontend:/app
      - /app/node_modules
    environment:
      - VITE_API_URL=http://localhost:8000

  backend:
    build:
      context: ../backend
      dockerfile: ../docker/Dockerfile.backend
    ports:
      - "8000:8000"
    volumes:
      - ../backend:/app
<% if (backend === 'fastapi') { %><% if (pythonPkgManager === 'uv') { %>      - /app/.venv
<% } %>
    environment:
      - DATABASE_URL=sqlite+aiosqlite:///./<%= projectName %>.db
<% if (pythonPkgManager === 'uv') { %>    command: uv run uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload
<% } else { %>    command: uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload
<% } %><% } else if (backend === 'express') { %>      - /app/node_modules
    environment:
      - DATABASE_URL=file:./<%= projectName %>.db
    command: npm run dev
<% } %>
