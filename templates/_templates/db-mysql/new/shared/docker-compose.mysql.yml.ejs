---
to: "<%= projectName %>/docker/docker-compose.local.yml"
force: true
skip_if: "<%= backend !== 'fastapi' && backend !== 'express' %>"
---
version: "3.8"

services:
  mysql:
    image: mysql:8.4
    ports:
      - "3306:3306"
    environment:
      MYSQL_DATABASE: <%= projectName %>
      MYSQL_ROOT_PASSWORD: root
    volumes:
      - mysql_data:/var/lib/mysql
    healthcheck:
      test: ["CMD-SHELL", "mysqladmin ping -h localhost -u root -proot"]
      interval: 5s
      timeout: 5s
      retries: 5

<% if (backend === 'fastapi') { %>
  frontend:
    build:
      context: ../frontend
      dockerfile: ../docker/Dockerfile.frontend
    ports:
      - "3000:3000"
    volumes:
      - ../frontend:/app
      - /app/node_modules
    environment:
      - VITE_API_URL=http://localhost:8000
    depends_on:
      - backend

  backend:
    build:
      context: ../backend
      dockerfile: ../docker/Dockerfile.backend
    ports:
      - "8000:8000"
    volumes:
      - ../backend:/app
    environment:
      - DATABASE_URL=mysql+aiomysql://root:root@mysql:3306/<%= projectName %>
<% if (pythonPkgManager === 'uv') { %>    command: uv run uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload
<% } else { %>    command: uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload
<% } %>    depends_on:
      mysql:
        condition: service_healthy
<% } else if (backend === 'express') { %>
  frontend:
    build:
      context: ../frontend
      dockerfile: ../docker/Dockerfile.frontend
    ports:
      - "3000:3000"
    volumes:
      - ../frontend:/app
      - /app/node_modules
    environment:
      - VITE_API_URL=http://localhost:8000
    depends_on:
      - backend

  backend:
    build:
      context: ../backend
      dockerfile: ../docker/Dockerfile.backend
    ports:
      - "8000:8000"
    volumes:
      - ../backend:/app
      - /app/node_modules
    environment:
      - DATABASE_URL=mysql://root:root@mysql:3306/<%= projectName %>
    command: npm run dev
    depends_on:
      mysql:
        condition: service_healthy
<% } %>

volumes:
  mysql_data:
